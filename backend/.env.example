# ==========================================================
#  IGNITE BLOG BACKEND - ENVIRONMENT VARIABLES
#  Bu faylni nusxalab ".env" deb nomlang va qiymatlarni to'ldiring.
#  Buyruq:  cp .env.example .env
# ==========================================================

# --- Server ---
NODE_ENV=development
PORT=5000

# Admin panel manzili (CORS uchun ruxsat beriladigan origin).
# Bir nechta bo'lsa vergul bilan ajrating: http://localhost:3000,https://admin.example.com
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ignite_blog?schema=public"

# --- JWT (Auth) ---
# Maxfiy kalit. Ishlab chiqarishda uzun, tasodifiy qiymat ishlating.
# Generatsiya: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Cloudinary (Media yuklash) ---
# https://cloudinary.com -> Dashboard'dan oling
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ignite-blog

# --- Birinchi admin (seed script ishlatadi) ---
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@igniteblog.com
ADMIN_PASSWORD=Admin12345!

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=300
